{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Accounts Executive Trainee Schema",
    "description": "Complete profile schema for accounts executive trainee role",
    "type": "object",
    "properties": {
      "whoIAm": {
        "type": "object",
        "title": "Who I Am",
        "description": "Basic personal information",
        "properties": {
          "name": {
            "type": "string",
            "title": "Full Name",
            "description": "Enter your full name",
            "required": true,
            "ui:widget": "text",
            "ui:placeholder": "Enter your full name",
            "ui:disabled": false,
            "ui:verified": false,
            "ui:verificationMessage": "✓ Verified from DigiLocker"
          },
          "location": {
            "type": "string",
            "title": "Location",
            "description": "Your current location",
            "required": true,
            "ui:widget": "text",
            "ui:placeholder": "Enter your current location",
            "ui:disabled": false,
            "ui:hasLocationButton": true
          },
          "phone": {
            "type": "string",
            "title": "Phone Number",
            "description": "Your contact phone number",
            "required": true,
            "pattern": "^[0-9]{10}$",
            "ui:widget": "tel",
            "ui:placeholder": "Enter phone number",
            "ui:disabled": false,
            "ui:verified": false
          },
          "age": {
            "type": "integer",
            "title": "Age",
            "description": "Your age",
            "required": true,
            "minimum": 14,
            "maximum": 65,
            "ui:widget": "number",
            "ui:placeholder": "Enter your age",
            "ui:disabled": false
          },
          "gender": {
          "type": "string",
          "title": "Gender",
          "description": "Gender of the candidate",
          "required": false,
          "ui:widget": "radio",
          "enum": ["Male", "Female", "Other"],
          "enumNames": ["Male", "Female", "Other"],
          "ui:placeholder": "Select your gender",
          "ui:disabled": false,
          "ui:verified": false,
          "ui:verificationMessage": "✓ Verified from DigiLocker"
        }
        },
        "required": ["name", "age", "location", "phone"],
        "ui": {
          "order": ["name", "age",  "gender", "location", "phone"],
          "description": "Enter your basic details or import from supported wallets for quick setup",
          "showWallet": true,
          "walletConfig": {
            "title": "Import from Wallets",
            "description": "Import verified credentials from supported digital wallets",
            "buttonText": "Import from Wallets",
            "footerText": "This will import your verified credentials, certificates, and personal details from Dhiway Wallet and DigiLocker"
          }
        }
      },
      "whatIHave": {
        "type": "object",
        "title": "What I Have",
        "description": "Your qualifications, skills, and experience",
        "properties": {
          "highestEducation": {
            "type": "string",
            "title": "Highest Educational Qualification",
            "description": "What is your highest qualification?",
            "required": true,
            "ui:widget": "select",
            "ui:placeholder": "Select your highest qualification",
            "ui:hasOther": true,
            "enum": ["12th Pass", "Graduate-B.Tech/B.E.", "Graduate-MBA HR", "Graduate-Other", "Other"],
            "enumNames": ["12th Pass", "Graduate-B.Tech/B.E.", "Graduate-MBA HR", "Graduate-Other", "Other"]
          },
          "softwareSkills": {
            "type": "array",
            "title": "Software Skills",
            "description": "Select all the softwares you are familiar with",
            "ui:widget": "multiselect-dropdown",
            "ui:placeholder": "Select software skills",
            "ui:disabled": false,
            "enum": ["Google Suite", "Excel","Tally","Other"],
            "enumNames": ["Google Suite", "Excel","Tally","Other"]
          },
          "taskVideo": {
            "type": "string",
            "title": "Document Upload",
            "description": "Upload any file (document, image, video) showing your work",
            "ui:widget": "file-upload",
            "ui:placeholder": "Upload file showing your work",
            "ui:disabled": false,
            "ui:accept": "*/*",
            "ui:noSizeLimit": true
          }
        },
        "required": ["highestEducation"],
        "ui": {
          "order": ["highestEducation", "softwareSkills", "taskVideo"],
          "description": "Tell us about your qualifications, skills, and experience"
        }
      },
      "whatIWant": {
        "type": "object",
        "title": "What I Want",
        "description": "Your salary expectations and work preferences",
        "properties": {
          "monthlyInHandPreferred": {
            "type": "integer",
            "title": "Monthly In-hand Preferred (INR)",
            "description": "Your expected monthly take-home salary",
            "minimum": 0,
            "maximum": 1000000,
            "ui:widget": "number",
            "ui:placeholder": "Enter amount in INR",
            "ui:currency": "₹",
            "ui:disabled": false
          }
        },
        "ui": {
          "order": ["monthlyInHandPreferred"],
          "description": "Tell us about your salary expectations and work preferences"
        }
      }
    },
    "ui": {
      "steps": [
        {
          "id": "whoIAm",
          "title": "Who I Am",
          "description": "Basic personal information",
          "icon": "User"
        },
        {
          "id": "whatIHave",
          "title": "What I Have",
          "description": "Qualifications, skills, and experience",
          "icon": "Briefcase"
        },
        {
          "id": "whatIWant",
          "title": "What I Want",
          "description": "Salary expectations and preferences",
          "icon": "Target"
        }
      ]
    }
  } 