{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Data Entry Operator Profile Schema",
    "description": "Complete profile schema for data entry operator role",
    "type": "object",
    "properties": {
      "whoIAm": {
        "type": "object",
        "title": "Who I Am",
        "description": "Basic personal information",
        "properties": {
          "name": {
            "type": "string",
            "title": "Full Name",
            "description": "Enter your full name",
            "required": true,
            "ui:widget": "text",
            "ui:placeholder": "Enter your full name",
            "ui:disabled": false,
            "ui:verified": false,
            "ui:verificationMessage": "✓ Verified from DigiLocker"
          },
          "location": {
            "type": "string",
            "title": "Location",
            "description": "Your current location",
            "required": true,
            "ui:widget": "text",
            "ui:placeholder": "Enter your current location",
            "ui:disabled": false,
            "ui:hasLocationButton": true
          },
          "phone": {
            "type": "string",
            "title": "Phone Number",
            "description": "Your contact phone number",
            "required": true,
            "pattern": "^[0-9]{10}$",
            "ui:widget": "tel",
            "ui:placeholder": "Enter phone number",
            "ui:disabled": false,
            "ui:verified": false
          },
          "age": {
            "type": "integer",
            "title": "Age",
            "description": "Your age",
            "minimum": 14,
            "maximum": 65,
            "ui:widget": "number",
            "ui:placeholder": "Enter your age",
            "ui:disabled": false
          }
        },
        "required": ["name", "location", "phone", "age"],
        "ui": {
          "order": ["name", "location", "phone", "age"],
          "description": "Enter your basic details or import from supported wallets for quick setup",
          "showWallet": true,
          "walletConfig": {
            "title": "Import from Wallets",
            "description": "Import verified credentials from supported digital wallets",
            "buttonText": "Import from Wallets",
            "footerText": "This will import your verified credentials, certificates, and personal details from Dhiway Wallet and DigiLocker"
          }
        }
      },
      "whatIHave": {
        "type": "object",
        "title": "What I Have",
        "description": "Your qualifications, skills, and experience",
        "properties": {
          "languagesKnown": {
            "type": "array",
            "title": "Languages Known",
            "description": "Select all languages you can speak",
            "ui:widget": "multiselect-dropdown",
            "ui:placeholder": "Select languages",
            "ui:hasOther": true,
            "enum": [
              "Assamese",
              "Bengali",
              "Bodo",
              "Dogri",
              "English",
              "Gujarati",
              "Hindi",
              "Kannada",
              "Kashmiri",
              "Konkani",
              "Maithili",
              "Malayalam",
              "Manipuri",
              "Marathi",
              "Mizo",
              "Nepali",
              "Odia",
              "Punjabi",
              "Sanskrit",
              "Santali",
              "Sindhi",
              "Tamil",
              "Telugu",
              "Urdu"
            ],
            "enumNames": [
              "Assamese (অসমীয়া)",
              "Bengali (বাংলা)",
              "Bodo (बड़ो)",
              "Dogri (डोगरी)",
              "English",
              "Gujarati (ગુજરાતી)",
              "Hindi (हिन्दी)",
              "Kannada (ಕನ್ನಡ)",
              "Kashmiri (कॉशुर)",
              "Konkani (कोंकणी)",
              "Maithili (मैथिली)",
              "Malayalam (മലയാളം)",
              "Manipuri (মৈতৈলোন্)",
              "Marathi (मराठी)",
              "Mizo (Mizo ṭawng)",
              "Nepali (नेपाली)",
              "Odia (ଓଡ଼ିଆ)",
              "Punjabi (ਪੰਜਾਬੀ)",
              "Sanskrit (संस्कृतम्)",
              "Santali (ᱥᱟᱱᱛᱟᱲᱤ)",
              "Sindhi (سنڌي)",
              "Tamil (தமிழ்)",
              "Telugu (తెలుగు)",
              "Urdu (اردو)"
            ]
          },
          "highestEducation": {
            "type": "string",
            "title": "Highest Educational Qualification",
            "description": "What is your highest qualification?",
            "ui:widget": "select",
            "ui:placeholder": "Select your highest qualification",
            "ui:hasOther": true,
            "enum": ["12th Pass", "Graduate-B.Tech/B.E.", "Graduate-MBA HR", "Other"],
            "enumNames": ["12th Pass", "Graduate-B.Tech/B.E.", "Graduate-MBA HR", "Other"]
          },
          "collegeName": {
            "type": "string",
            "title": "College Name",
            "description": "Enter your college or institution name",
            "ui:widget": "text",
            "ui:placeholder": "Enter college name",
            "ui:disabled": false
          },
          "workExperience": {
            "type": "string",
            "title": "Work Experience",
            "description": "What is your work experience level?",
            "enum": ["None", "Less than 1 year", "Less than 2 years", "More than 2 years"],
            "enumNames": ["None", "Less than 1 year", "Less than 2 years", "More than 2 years"],
            "ui:widget": "select",
            "ui:placeholder": "Select your work experience",
            "ui:disabled": false
          },
          "softwareSkills": {
            "type": "array",
            "title": "Software Skills",
            "description": "Select all the softwares you are familiar with",
            "ui:widget": "multiselect-dropdown",
            "ui:placeholder": "Select software skills",
            "ui:disabled": false,
            "enum": ["Google Suite", "Excel","Tally","Other"],
            "enumNames": ["Google Suite", "Excel","Tally","Other"]
          },
          "taskVideo": {
            "type": "string",
            "title": "Task Upload",
            "description": "Upload any file (document, image, video) showing your work",
            "ui:widget": "file-upload",
            "ui:placeholder": "Upload file showing your work",
            "ui:disabled": false,
            "ui:accept": "*/*",
            "ui:noSizeLimit": true
          },
          "scanQRCode": {
            "type": "string",
            "title": "Scan QR Code",
            "description": "Scan QR code to import additional information",
            "required": false,
            "ui:widget": "qr-scanner",
            "ui:placeholder": "Scan QR code"
          }
        },
        "required": ["highestEducation"],
        "ui": {
          "order": ["languagesKnown", "highestEducation", "collegeName", "workExperience", "softwareSkills", "taskVideo", "scanQRCode"],
          "description": "Tell us about your qualifications, skills, and experience"
        }
      },
      "whatIWant": {
        "type": "object",
        "title": "What I Want",
        "description": "Your salary expectations and work preferences",
        "properties": {
          "workHoursPerDay": {
            "type": "integer",
            "title": "Number of hours willing to work / day",
            "description": "How many hours are you willing to work per day?",
            "minimum": 4,
            "maximum": 12,
            "ui:widget": "number",
            "ui:placeholder": "Enter hours (4-12)",
            "ui:disabled": false
          },
          "preferredWorkMode": {
            "type": "array",
            "title": "Preferred mode of work",
            "description": "Select your preferred work arrangements",
            "ui:widget": "multiselect-dropdown",
            "ui:placeholder": "Select work modes",
            "ui:hasOther": true,
            "enum": ["On-site-no shift", "On-site-shift", "Remote", "Hybrid", "Travelling", "Apprenticeship"],
            "enumNames": ["On-site-no shift", "On-site-shift", "Remote", "Hybrid", "Travelling", "Apprenticeship"]
          },
          "monthlyInHandPreferred": {
            "type": "integer",
            "title": "Monthly In-hand Preferred (INR)",
            "description": "Your expected monthly take-home salary",
            "minimum": 0,
            "maximum": 1000000,
            "ui:widget": "number",
            "ui:placeholder": "Enter amount in INR",
            "ui:currency": "₹",
            "ui:disabled": false
          },
          "monthlyPerformanceVariable": {
            "type": "integer",
            "title": "Monthly performance based variable expectation (INR)",
            "description": "Expected performance-based variable pay",
            "required": false,
            "minimum": 0,
            "maximum": 50000,
            "ui:widget": "number",
            "ui:placeholder": "Enter amount in INR",
            "ui:currency": "₹",
            "ui:disabled": false
          }
        },
        "ui": {
          "order": ["workHoursPerDay", "preferredWorkMode", "monthlyInHandPreferred", "monthlyPerformanceVariable"],
          "description": "Tell us about your salary expectations and work preferences"
        }
      }
    },
    "ui": {
      "steps": [
        {
          "id": "whoIAm",
          "title": "Who I Am",
          "description": "Basic personal information",
          "icon": "User"
        },
        {
          "id": "whatIHave",
          "title": "What I Have",
          "description": "Qualifications, skills, and experience",
          "icon": "Briefcase"
        },
        {
          "id": "whatIWant",
          "title": "What I Want",
          "description": "Salary expectations and preferences",
          "icon": "Target"
        }
      ]
    }
  } 