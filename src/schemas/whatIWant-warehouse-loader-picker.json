{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "What I Want - Salary & Preferences",
  "description": "Schema for salary expectations and work preferences step for a Warehouse Loader and Picker.",
  "type": "object",
  "properties": {
    "monthlySalary": {
      "type": "integer",
      "title": "Expected Monthly Salary",
      "description": "Your expected monthly salary in INR",
      "minimum": 0,
      "ui:widget": "number",
      "ui:placeholder": "Expected monthly salary",
      "ui:currency": "₹",
      "ui:autoCalculate": "inHandSalary"
    },
    "salaryFrequency": {
      "type": "string",
      "title": "Payment Frequency",
      "description": "How often you want to be paid",
      "enum": ["weekly", "monthly"],
      "enumNames": ["Weekly", "Monthly"],
      "ui:widget": "select",
      "ui:placeholder": "Select frequency"
    },
    "pfDeduction": {
      "type": "integer",
      "title": "PF Deduction",
      "description": "Provident Fund deduction amount in INR",
      "minimum": 0,
      "ui:widget": "number",
      "ui:placeholder": "PF deduction amount",
      "ui:currency": "₹",
      "ui:autoCalculate": "inHandSalary"
    },
    "esicDeduction": {
      "type": "integer",
      "title": "ESIC Deduction",
      "description": "ESIC deduction amount in INR",
      "minimum": 0,
      "ui:widget": "number",
      "ui:placeholder": "ESIC deduction amount",
      "ui:currency": "₹",
      "ui:autoCalculate": "inHandSalary"
    },
    "inHandSalary": {
      "type": "integer",
      "title": "Take-Home Salary",
      "description": "Your take-home salary after deductions",
      "minimum": 0,
      "ui:widget": "number",
      "ui:placeholder": "Auto-calculated",
      "ui:currency": "₹",
      "ui:disabled": true,
      "ui:calculation": "monthlySalary - pfDeduction - esicDeduction",
      "ui:helpText": "Automatically calculated: Monthly Salary - PF - ESIC"
    },
    "advanceMonthsAvailable": {
      "type": "integer",
      "title": "Advance Months Available",
      "description": "Number of months of advance salary available",
      "minimum": 0,
      "ui:widget": "number",
      "ui:placeholder": "Number of months"
    },
    "advanceFrequency": {
      "type": "string",
      "title": "Advance Frequency",
      "description": "How often advance salary is provided",
      "enum": ["monthly", "quarterly", "half-yearly"],
      "enumNames": ["Monthly", "Quarterly", "Half Yearly"],
      "ui:widget": "select",
      "ui:placeholder": "Select frequency"
    },
    "housingFacility": {
      "type": "boolean",
      "title": "Housing Facility Required",
      "description": "Do you need housing facility?",
      "default": false,
      "ui:widget": "checkbox",
      "ui:icon": "Home"
    },
    "foodFacility": {
      "type": "boolean",
      "title": "Food Facility Required",
      "description": "Do you need food facility?",
      "default": false,
      "ui:widget": "checkbox",
      "ui:icon": "Utensils"
    },
    "workHoursPerDay": {
      "type": "integer",
      "title": "Preferred Work Hours per Day",
      "description": "Your preferred working hours per day",
      "minimum": 1,
      "maximum": 24,
      "ui:widget": "number",
      "ui:placeholder": "Regular hours (e.g., 8)"
    },
    "overtimePayMultiplier": {
      "type": "number",
      "title": "Overtime Pay Rate",
      "description": "Your expected overtime pay rate",
      "enum": [1, 1.5, 2],
      "enumNames": ["1X (Normal Rate)", "1.5X (Time and Half)", "2X (Double Time)"],
      "ui:widget": "select",
      "ui:placeholder": "Select rate"
    },
    "overtimeAvailable": {
      "type": "boolean",
      "title": "Willing to work overtime",
      "description": "Are you willing to work overtime?",
      "default": false,
      "ui:widget": "checkbox"
    },
    "gradeUpgradation": {
      "type": "boolean",
      "title": "Interested in career growth opportunities",
      "description": "Are you interested in career growth and grade upgradation?",
      "default": false,
      "ui:widget": "checkbox"
    }
  },
  "ui": {
    "order": [
      "monthlySalary",
      "salaryFrequency",
      "pfDeduction",
      "esicDeduction",
      "inHandSalary",
      "advanceMonthsAvailable",
      "advanceFrequency",
      "housingFacility",
      "foodFacility",
      "workHoursPerDay",
      "overtimePayMultiplier",
      "overtimeAvailable",
      "gradeUpgradation"
    ],
    "description": "Tell us about your salary expectations and work preferences for a warehouse role.",
    "sections": [
      {
        "title": "Salary & Benefits",
        "icon": "Calculator",
        "fields": [
          "monthlySalary",
          "salaryFrequency",
          "pfDeduction",
          "esicDeduction",
          "inHandSalary"
        ],
        "subsections": [
          {
            "title": "Advance Options",
            "fields": ["advanceMonthsAvailable", "advanceFrequency"]
          }
        ]
      },
      {
        "title": "Required Facilities",
        "fields": ["housingFacility", "foodFacility"]
      },
      {
        "title": "Work Preferences",
        "fields": [
          "workHoursPerDay",
          "overtimePayMultiplier",
          "overtimeAvailable",
          "gradeUpgradation"
        ]
      }
    ],
    "autoCalculations": {
      "inHandSalary": {
        "formula": "monthlySalary - pfDeduction - esicDeduction",
        "dependencies": ["monthlySalary", "pfDeduction", "esicDeduction"]
      }
    }
  }
} 