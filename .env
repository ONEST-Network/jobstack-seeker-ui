# Organization API Key for fetching org details
VITE_ORG_API_KEY=<org-key> #check key from other repo
VITE_OUTBOUND_CALL_URL=https://profile-manager-onest.dhiway.net 
VITE_OUTBOUND_API_KEY=<secret>

# Google Maps Configuration
VITE_USE_GOOGLE_MAPS=true
VITE_GOOGLE_MAPS_API_KEY=<get-key-from-GCP>
VITE_GOOGLE_GEOCODING_API_KEY=<get-key-from-GCP>
VITE_GOOGLE_PLACES_API_KEY=<get-key-from-GCP>
