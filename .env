VITE_API_BASE_URL=http://localhost:3001/api/v1
# VITE_APP_ENV=development
VITE_AGENT_URL=https://agent.dev.demo.dhiway.com
VITE_AGENT_TOKEN=<your-secret> # get your secret for digilocker integration
VITE_VC_WALLET_URL = https://vc-wallet.dhiway.net

VITE_BAP_URL = https://onest-demo-lite-bap.dhiway.net # URL hosted from repo https://github.com/dhiway/jobstack-bap
